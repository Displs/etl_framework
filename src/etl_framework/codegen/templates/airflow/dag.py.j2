"""Автоматически сгенерированный DAG Airflow.

НЕ РЕДАКТИРОВАТЬ ВРУЧНУЮ.
Сгенерировано etl-framework v{{ framework_version }} в {{ generated_at }}.
"""

from __future__ import annotations

from datetime import datetime, timedelta

from airflow import DAG
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator

DEFAULT_ARGS = {
    "owner": "etl-framework",
    "depends_on_past": False,
    "retries": {{ default_retries }},
    "retry_delay": timedelta(minutes={{ default_retry_delay }}),
}

with DAG(
    dag_id="{{ dag_id }}",
    description="DAG ETL, сгенерированный из репозитория активных метаданных",
    default_args=DEFAULT_ARGS,
    start_date=datetime.fromisoformat("{{ start_date }}"),
    schedule="{{ cron }}",
    catchup={{ catchup }},
    max_active_runs=1,
    tags=["etl-framework", "auto-generated"],
) as dag:
    tasks: dict[str, SparkSubmitOperator] = {}

{% for task in tasks %}
    tasks["{{ task.name }}"] = SparkSubmitOperator(
        task_id="{{ task.name }}",
        application="{{ application_root }}/{{ task.name }}.py",
        name="etl_{{ task.name }}",
        conn_id="spark_default",
        application_args=[
            "--load-ts", "{{ '{{ ts }}' }}",
{% if task.is_incremental %}
            "--lower-bound", "{{ '{{ prev_data_interval_start_success or data_interval_start }}' }}",
{% endif %}
        ],
        verbose=False,
    )
{% endfor %}

{% for task in tasks %}
{% for dep in task.depends_on %}
    tasks["{{ dep }}"] >> tasks["{{ task.name }}"]
{% endfor %}
{% endfor %}
