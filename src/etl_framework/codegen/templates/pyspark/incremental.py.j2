{% from "pyspark/_macros.j2" import file_header, common_imports, extract_fn, transform_fn %}
{{ file_header(spec, framework_version, generated_at) }}
{{ common_imports() }}


TARGET = "{{ spec.target.fqn }}"
WATERMARK_COLUMN = "{{ spec.load.watermark_column }}"
BUSINESS_KEYS = [{% for k in spec.load.business_keys %}"{{ k }}"{% if not loop.last %}, {% endif %}{% endfor %}]


{{ extract_fn(spec, source) }}


{{ transform_fn(spec) }}


def append(df: DataFrame) -> None:
    # Инкрементальная дозагрузка — режим append; идемпотентность
    # обеспечивает фильтр по watermark на стороне извлечения.
    log.info("инкрементальная дозагрузка в %s (watermark=%s)", TARGET, WATERMARK_COLUMN)
    df.writeTo(TARGET).using("{{ spec.target.format.value }}").append()


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="ETL-задача для {{ spec.metadata.name }}")
    parser.add_argument("--load-ts", default=None)
    parser.add_argument(
        "--lower-bound",
        default=None,
        help="ISO-таймстемп; в загрузку идут строки с watermark > lower_bound",
    )
    args = parser.parse_args(argv)
    load_ts = (
        datetime.fromisoformat(args.load_ts) if args.load_ts else datetime.now(timezone.utc)
    )

    spark = SparkSession.builder.appName("etl_{{ spec.metadata.name }}").getOrCreate()
    try:
        raw = extract(spark, args.lower_bound)
        prepared = transform(raw, load_ts)
        append(prepared)
        new_max = prepared.agg(F.max(WATERMARK_COLUMN)).collect()[0][0]
        log.info("инкрементальная загрузка завершена; новый максимум watermark = %s", new_max)
        if new_max is not None:
            # Печатается в stdout — пробрасывается обратно в Airflow через XCom.
            print(f"WATERMARK={new_max}")
    finally:
        spark.stop()
    return 0


if __name__ == "__main__":
    sys.exit(main())
