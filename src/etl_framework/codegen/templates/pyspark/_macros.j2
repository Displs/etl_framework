{# Общие макросы для PySpark-шаблонов. #}

{%- macro file_header(spec, framework_version, generated_at) -%}
"""ETL-задача для сущности '{{ spec.metadata.name }}' (слой={{ spec.metadata.layer.value }}, стратегия={{ spec.load.strategy.value }}).

НЕ РЕДАКТИРОВАТЬ ВРУЧНУЮ.
Сгенерировано etl-framework v{{ framework_version }} в {{ generated_at }}.
Источник: {{ spec.source.ref }}
Цель: {{ spec.target.fqn }}
"""
{%- endmacro -%}

{%- macro common_imports() -%}
from __future__ import annotations

import argparse
import logging
import sys
from datetime import datetime, timezone

from pyspark.sql import DataFrame, SparkSession, functions as F

from etl_framework.security.secrets import resolve_secret

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(name)s: %(message)s")
log = logging.getLogger(__name__)
{%- endmacro -%}

{%- macro extract_fn(spec, source) -%}
def extract(spark: SparkSession, lower_bound: str | None) -> DataFrame:
    # Чтение из источника через JDBC; учётные данные — ссылки на секреты,
    # разрешаются на стороне исполнителя.
    user = resolve_secret({{ source.connection.user | py_literal }})
    password = resolve_secret({{ source.connection.password | py_literal }})
    jdbc_url = (
        "jdbc:postgresql://{{ source.connection.host }}:{{ source.connection.port }}"
        "/{{ source.connection.database }}"
    )
    reader = (
        spark.read.format("jdbc")
        .option("url", jdbc_url)
        .option("user", user)
        .option("password", password)
        .option("driver", "org.postgresql.Driver")
        .option("fetchsize", "10000")
    )
{% if spec.load.strategy.value == 'incremental' %}
    if lower_bound is None:
        log.warning("lower_bound не задан; выполняется полное снятие снимка")
        return reader.option(
            "dbtable", "{{ spec.source.schema_ }}.{{ spec.source.table }}"
        ).load()
    log.info("инкрементальное чтение с lower_bound=%s", lower_bound)
    query = (
        "(select * from {{ spec.source.schema_ }}.{{ spec.source.table }} "
        f"where {{ spec.load.watermark_column }} > '{lower_bound}'::timestamp) src"
    )
    return reader.option("dbtable", query).load()
{% else %}
    return reader.option(
        "dbtable", "{{ spec.source.schema_ }}.{{ spec.source.table }}"
    ).load()
{% endif %}
{%- endmacro -%}

{%- macro transform_fn(spec) -%}
def transform(df: DataFrame, load_ts: datetime) -> DataFrame:
    # Проекция исходного DataFrame по правилам маппинга из спецификации.
    projected = df.selectExpr(
{% for col in spec.mapping %}
        "{{ col.render_expression() }} as {{ col.target }}"{% if not loop.last %},{% endif %}
{% endfor %}
    )
    # Добавление технических колонок аудита (timestamp загрузки, имя системы,
    # хеш записи для последующих сверок и обнаружения изменений).
    enriched = (
        projected
        .withColumn(
            "{{ spec.audit.load_ts_column }}",
            F.lit(load_ts.isoformat()).cast("timestamp"),
        )
        .withColumn(
            "{{ spec.audit.source_system_column }}",
            F.lit("{{ spec.source.source_name }}"),
        )
{% if spec.audit.record_hash_column %}
        .withColumn(
            "{{ spec.audit.record_hash_column }}",
            F.sha2(
                F.concat_ws("||",
{% for col in spec.mapping %}
                    F.coalesce(F.col("{{ col.target }}").cast("string"), F.lit("")){% if not loop.last %},{% endif %}
{% endfor %}
                ),
                256,
            ),
        )
{% endif %}
    )
    return enriched
{%- endmacro -%}
